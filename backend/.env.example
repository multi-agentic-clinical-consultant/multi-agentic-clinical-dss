# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Groq (LLM for doctor + prescription agents) ───────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile   # optional, this is the default

# ── Deepgram (STT + TTS) ──────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── ElevenLabs (optional – higher quality TTS) ────────────────────────────────
# If set, ElevenLabs is used instead of Deepgram Aura for TTS.
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ── Moss (medical knowledge RAG – optional) ───────────────────────────────────
# If not set, the doctor agent will rely on LLM training only.
MOSS_PROJECT_ID=your_moss_project_id
MOSS_PROJECT_KEY=your_moss_project_key
MOSS_INDEX_NAME=medical_knowledge
